# QoS Buddy environment variables.
# Copy to `.env` and fill in real values, or export them in your shell.
# `.env` is gitignored; never commit your real token.

# --- App mode ---
# demo: local-first demo defaults
# dev: local development defaults
# prod: no default bearer tokens, no default CORS origins, secure session cookies,
#       and no fallback to bundled sample telemetry when live monitoring data is absent
QOS_APP_MODE=dev

# --- Auth tokens (comma-separated; tokens map to roles via QOS_TOKENS_*) ---
QOS_TOKENS_VIEWER=viewer-dev-token
QOS_TOKENS_ENGINEER=engineer-dev-token
QOS_TOKENS_LEAD=lead-dev-token

# --- Local Ollama reasoner ---
QOS_OLLAMA_URL=http://localhost:11434/api/generate
QOS_OLLAMA_TAGS_URL=http://localhost:11434/api/tags
QOS_LLM_MODEL=qwen2.5:3b
QOS_LLM_TIMEOUT_S=45
QOS_LLM_PROBE_TIMEOUT_S=2

# --- Approval SLAs (seconds) ---
QOS_SLA_LOW_S=900
QOS_SLA_MEDIUM_S=600
QOS_SLA_HIGH_S=300
QOS_SLA_CRITICAL_S=180

# --- API / browser access ---
QOS_CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
QOS_SESSION_COOKIE_NAME=qos_session
QOS_SESSION_COOKIE_SECURE=false
QOS_SESSION_TTL_S=28800

# --- Autonomous agent runtime (disabled by default) ---
QOS_AGENT_AUTOSTART=false
QOS_AGENT_STARTUP_RUN=false
QOS_AGENT_INTERVAL_S=30
# QOS_AGENT_STARTUP_CELL_ID=CELL-001

# --- Jira Cloud integration ---
# JIRA_URL: your Atlassian Cloud site, no trailing slash, e.g. https://acme.atlassian.net
# JIRA_EMAIL: the Atlassian account email associated with the API token below.
# JIRA_TOKEN: an API token from https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_PROJECT_KEY: the project key (NOT the name), e.g. NOC, OPS, INFRA.
# JIRA_ISSUE_TYPE: one of the issue types enabled on the project (Task, Bug, Incident, etc.).
# JIRA_DONE_TRANSITIONS: comma-separated transition names tried when closing.
#   Used as fallback when no Done-category transition is exposed; first match wins.
# JIRA_TIMEOUT_S: HTTP timeout in seconds for all Jira REST calls.
JIRA_URL=
JIRA_EMAIL=
JIRA_TOKEN=
JIRA_PROJECT_KEY=
JIRA_ISSUE_TYPE=Task
JIRA_DONE_TRANSITIONS=Done,Close,Closed,Resolve,Resolve Issue
JIRA_TIMEOUT_S=10

# --- MLflow ---
# QOS_MLFLOW_TRACKING_URI defaults to a local SQLite DB; override for a server.
# QOS_MLFLOW_TRACKING_URI=http://localhost:5000
QOS_MLFLOW_EXPERIMENT=qos_phase3_deployment

# --- Replay ---
QOS_REPLAY_SPEED=8
