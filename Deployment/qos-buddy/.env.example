# Copy to .env and fill in real values, then run:
#   docker compose --env-file .env up -d
#
# Live Jira integration: flip QOS_JIRA_ENABLED to "true" when credentials are ready.
#
# Get your API token at: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_URL format:       https://your-org.atlassian.net

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me
POSTGRES_PASSWORD=change-me

# Default deployment tails the real collector JSONL. Use replay only for
# intentional offline backfill/demo runs.
QOS_MONITORING_MODE=tail

QOS_JIRA_ENABLED=false
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_TOKEN=your-api-token-here
JIRA_PROJECT_KEY=QOS
